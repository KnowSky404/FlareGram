# Worker deployment config
WORKER_NAME=flaregram
MAIN=src/index.ts
COMPATIBILITY_DATE=2026-04-27

# Optional. Leave empty to use the default workers.dev domain.
CUSTOM_DOMAIN=flaregram.example.com

# D1 binding config
D1_DATABASE_NAME=flaregram
D1_DATABASE_ID=REPLACE_WITH_D1_DATABASE_ID

# Runtime variables and secrets
ADMIN_CHAT_ID=REPLACE_WITH_ADMIN_CHAT_ID
BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
WEBHOOK_SECRET=REPLACE_WITH_RANDOM_WEBHOOK_SECRET

# Optional. Leave empty unless you need to pin Telegram getMe output manually.
BOT_INFO=
