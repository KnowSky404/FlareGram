{
  "name": "flaregram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "configure": "node scripts/configure.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 execute DB --local --file=src/db/migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute DB --remote --file=src/db/migrations/0001_initial.sql"
  },
  "dependencies": {
    "grammy": "^1.38.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260416.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "wrangler": "^4.13.2"
  }
}
